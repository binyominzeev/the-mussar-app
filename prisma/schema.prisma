generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  goals                        Goal[]
  checkins                     Checkin[]
  accountabilityPairsAsUser    AccountabilityPair[] @relation("UserPairs")
  accountabilityPairsAsPartner AccountabilityPair[] @relation("PartnerPairs")
}

model Goal {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  createdAt   DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  focuses Focus[]
}

model Focus {
  id          String   @id @default(cuid())
  goalId      String
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())

  goal    Goal     @relation(fields: [goalId], references: [id])
  actions Action[]
}

model Action {
  id      String @id @default(cuid())
  focusId String
  title   String
  type    String

  focus    Focus     @relation(fields: [focusId], references: [id])
  checkins Checkin[]
}

model Checkin {
  id       String   @id @default(cuid())
  userId   String
  date     DateTime
  actionId String
  value    String

  user   User   @relation(fields: [userId], references: [id])
  action Action @relation(fields: [actionId], references: [id])

  @@unique([userId, date, actionId])
}

model AccountabilityPair {
  id        String @id @default(cuid())
  userId    String
  partnerId String
  type      String

  user    User @relation("UserPairs", fields: [userId], references: [id])
  partner User @relation("PartnerPairs", fields: [partnerId], references: [id])
}
